# =============================================================================
# HRIS Philippine Payroll - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# For Vercel deployment, add these in your Vercel project settings:
#   Settings > Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (Required)
# -----------------------------------------------------------------------------
# For local development:
#   postgresql://username:password@localhost:5432/hris_payroll
#
# For Vercel Postgres (auto-populated when you add Vercel Postgres integration):
#   postgres://default:xxxxx@ep-xxxxx.us-east-1.aws.neon.tech/verceldb?sslmode=require
#
# For external providers (Neon, Supabase, Railway, etc.):
#   Use the connection string from your provider's dashboard.
#
DATABASE_URL="postgresql://username:password@localhost:5432/hris_payroll"

# If using Vercel Postgres, you may also need (auto-populated):
# POSTGRES_PRISMA_URL="..."        # Connection pooling URL
# POSTGRES_URL_NON_POOLING="..."   # Direct connection URL (for migrations)

# -----------------------------------------------------------------------------
# NEXTAUTH (Required)
# -----------------------------------------------------------------------------
# A random secret string used to encrypt session tokens.
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET="change-this-to-a-random-secret-key"

# The canonical URL of your deployed application.
# For local development: http://localhost:3000
# For Vercel: https://your-project-name.vercel.app (auto-set by Vercel)
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# AWS S3 - Document Storage (Optional)
# -----------------------------------------------------------------------------
# Only needed if you want to store payslips and employee documents in S3.
# If not configured, document upload features will be unavailable.
#
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"
# AWS_REGION="us-west-2"
# AWS_BUCKET_NAME="your-bucket-name"
# AWS_FOLDER_PREFIX="hris/"
