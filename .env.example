# =============================================================================
# HRIS Philippine Payroll - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for LOCAL development.
# For Vercel deployment, add these in your Vercel project dashboard:
#   Settings → Environment Variables
#
# See ENVIRONMENT_VARIABLES.md for detailed explanations of each variable.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. DATABASE (Required)
# -----------------------------------------------------------------------------
# PostgreSQL connection string from your database provider.
#
# Local development:
#   postgresql://username:password@localhost:5432/hris_payroll
#
# Neon (recommended for Vercel):
#   postgresql://user:pass@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
#
# Supabase:
#   postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
#
# Railway:
#   postgresql://postgres:[password]@[host].railway.app:5432/railway
#
DATABASE_URL="postgresql://username:password@localhost:5432/hris_payroll?connect_timeout=15"

# -----------------------------------------------------------------------------
# 2. NEXTAUTH (Required)
# -----------------------------------------------------------------------------
# Random secret for encrypting session tokens and JWTs.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-this-to-a-random-secret-key"

# The canonical URL where your app is hosted.
# Local development: http://localhost:3000
# Vercel: https://your-project.vercel.app  (Vercel auto-sets this — but set
#         it explicitly if you use a custom domain)
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# 3. AWS S3 - Document Storage (Optional)
# -----------------------------------------------------------------------------
# Required only if you want to upload/store payslips, employee documents, etc.
# If not configured, file-upload features will be unavailable.
#
# AWS_ACCESS_KEY_ID="AKIA..."
# AWS_SECRET_ACCESS_KEY="your-secret-key"
# AWS_REGION="ap-southeast-1"
# AWS_BUCKET_NAME="your-hris-bucket"
# AWS_FOLDER_PREFIX="hris/"

# Client-side region hint (used by front-end upload components)
# NEXT_PUBLIC_AWS_REGION="ap-southeast-1"

# -----------------------------------------------------------------------------
# 4. NODE ENVIRONMENT (Auto-set by Vercel — do NOT override)
# -----------------------------------------------------------------------------
# NODE_ENV="production"
