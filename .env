# Database - Update with your PostgreSQL connection string
DATABASE_URL="postgresql://username:password@localhost:5432/hris_payroll?connect_timeout=15"

# NextAuth Configuration
NEXTAUTH_SECRET="change-this-to-a-random-secret-key"
NEXTAUTH_URL="http://localhost:3000"

# Optional: AWS S3 for document storage (payslips, employee documents)
# AWS_PROFILE=hosted_storage
# AWS_REGION=us-west-2
# AWS_BUCKET_NAME=your-bucket-name
# AWS_FOLDER_PREFIX=hris/
